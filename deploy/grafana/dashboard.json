{
  "annotations": { "list": [] },
  "description": "mp-relay pipeline observability — submission flow, JAV search hit rate, post-download pipeline outcomes, QC pass/fail, mdcx success, in-flight task distribution.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Submissions / 5min by kind",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "stacking": { "mode": "normal" } },
          "unit": "short"
        }
      },
      "options": { "legend": { "displayMode": "table", "calcs": ["sum"] } },
      "targets": [
        {
          "expr": "sum by (kind, result) (increase(mp_relay_submit_total[5m]))",
          "legendFormat": "{{kind}} / {{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Pipeline runs (terminal state) / 1h",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 6 },
      "options": { "legend": { "displayMode": "table", "calcs": ["sum"] } },
      "targets": [
        {
          "expr": "sum by (terminal_state) (increase(mp_relay_pipeline_run_total[1h]))",
          "legendFormat": "{{terminal_state}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "QC pass rate (1h)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 6, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0.5, "color": "orange" },
              { "value": 0.8, "color": "green" }
            ]
          }
        }
      },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum(increase(mp_relay_qc_total{result=\"pass\"}[1h])) / clamp_min(sum(increase(mp_relay_qc_total[1h])), 1)",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "QC retries (1h)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 6, "w": 6, "h": 4 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum by (outcome) (increase(mp_relay_qc_retry_total[1h]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Multipart merges / Disc remux (1h)",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 4 },
      "targets": [
        {
          "expr": "sum by (outcome) (increase(mp_relay_multipart_merged_total[1h]))",
          "legendFormat": "merge / {{outcome}}",
          "refId": "A"
        },
        {
          "expr": "sum by (kind, outcome) (increase(mp_relay_disc_remux_total[1h]))",
          "legendFormat": "remux {{kind}} / {{outcome}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "Pipeline step duration (p50/p95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (step, le) (rate(mp_relay_pipeline_step_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{step}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (step, le) (rate(mp_relay_pipeline_step_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{step}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 7,
      "title": "JAV search rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 6 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        {
          "expr": "sum by (result) (rate(mp_relay_jav_search_total[5m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "In-flight tasks by state",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "stacking": { "mode": "normal" } },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "mp_relay_inflight",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Files deleted / 1h by category",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "sum by (category) (increase(mp_relay_files_deleted_total[1h]))",
          "legendFormat": "{{category}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "mdcx scrape outcomes / 1h",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 6 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum by (result) (increase(mp_relay_mdcx_total[1h]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["mp-relay", "jav", "homelab"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "mp-relay pipeline",
  "uid": "mp-relay-pipeline",
  "version": 1,
  "weekStart": ""
}
