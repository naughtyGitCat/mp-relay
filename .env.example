# mp-relay configuration. Copy to .env and fill in.
# All keys are optional — defaults match user's homelab.

# MoviePilot home instance (regular movies/TV)
MP_URL=http://10.100.100.13:3000
MP_USER=admin
MP_PASS=change-me

# qBittorrent WebUI (must be reachable from where mp-relay runs)
QBT_URL=http://127.0.0.1:8080
QBT_USER=admin
QBT_PASS=change-me

# Where qBT puts JAV downloads. Created/updated as a category at startup.
QBT_JAV_CATEGORY=JAV
QBT_JAV_SAVEPATH=G:\Downloads\JAV-staging

# MDCX fork (LLM-friendly CLI). NOT the old GUI at E:\MDC.
MDCX_DIR=E:\mdcx-src
MDCX_PYTHON=E:\mdcx-src\.venv\Scripts\python.exe
MDCX_MODULE=mdcx.cmd.main

# Service
LISTEN_HOST=0.0.0.0
LISTEN_PORT=5000
WATCHER_INTERVAL_SEC=60
MDCX_SETTLE_SEC=30
STATE_DB=state.db
